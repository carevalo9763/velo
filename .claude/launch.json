{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "velo",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "require('http').createServer((req,res)=>{const fs=require('fs'),path=require('path');let f=path.join('/Users/christianarevalo/Documents/GitHub/velo',req.url==='/'?'/index.html':req.url);fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end();}else{const ext=path.extname(f);const t={'html':'text/html','css':'text/css','js':'text/javascript','png':'image/png','mp4':'video/mp4'}[ext.slice(1)]||'text/plain';res.writeHead(200,{'Content-Type':t});res.end(d);}});}).listen(3000)"],
      "port": 3000
    }
  ]
}
